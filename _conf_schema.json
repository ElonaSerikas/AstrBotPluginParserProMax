                        "description": "B站视频编码",
                        "hint": "优先下载的编码类型，可选：AVC、AV1、HEV。推荐用兼容性较好的AVC",
                        "type": "string",
                        "options": [
                            "AVC",
                            "AV1",
                            "HEV"
                        ],
                        "default": "AVC"
                    },
                    "video_quality": {
                        "description": "B站视频分辨率",
                        "hint": "下载B站视频的分辨率, 高画质可能需要登录才能下载成功",
                        "type": "string",
                        "options": [
                            "_360P",
                            "_480P",
                            "_720P",
                            "_1080P",
                            "_1080P_PLUS",
                            "_1080P_60",
                            "_4K",
                            "HDR",
